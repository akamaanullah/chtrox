APP_NAME=ChatRox
APP_DEBUG=false
APP_ENV=local
BASE_URL=http://localhost/chatrox

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chatrox
DB_USERNAME=root
DB_PASSWORD=
DB_TIMEZONE=+05:00

# Get a free key at https://developers.giphy.com/dashboard/
GIPHY_API_KEY=

# Max single-file upload size (MB). Must be <= PHP upload_max_filesize / post_max_size.
MAX_FILE_SIZE_MB=40
WS_PORT=8088
WS_BIND=0.0.0.0

# Comma-separated IPs of trusted reverse proxies (leave empty for direct connections)
TRUSTED_PROXIES=
